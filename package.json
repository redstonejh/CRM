{
  "name": "crm-client",
  "productName": "CRM",
  "version": "0.1.0",
  "description": "Modular CRM client assembled from the shared ticketing canvas, card stacks, and fractal calendar.",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "server": "node server/index.js",
    "db:migrate": "node server/migrate.js",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "visual": "node tools/visual/shoot.js",
    "visual:serve": "node tools/visual/harness.js",
    "visual:update": "node tools/visual/visual-diff.js --update",
    "visual:motion": "node tools/visual/motion-check.js",
    "visual:scenes": "node tools/visual/scenes.js",
    "visual:census": "node tools/visual/census-gallery.js",
    "test:visual": "node tools/visual/visual-diff.js",
    "test:factory": "node tools/visual/factory-check.js",
    "test:interaction": "node tools/visual/interaction-contract.js",
    "test:ws": "node tools/visual/ws-parity-test.js",
    "test": "npm run test:ws && npm run test:factory && npm run test:interaction && npm run test:visual"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "pg": "^8.22.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.0.0",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.0.0",
    "@electron-forge/plugin-fuses": "^7.0.0",
    "@electron-forge/plugin-vite": "^7.0.0",
    "@electron/fuses": "^1.8.0",
    "electron": "^34.0.0",
    "pg-mem": "^3.0.14",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "puppeteer-core": "^25.3.0",
    "vite": "^6.0.0"
  }
}
